# Core
ENV=dev
DOMUSMIND_DEBUG=false

# Database
DB_PASSWORD=change_me_domusmind
DATABASE_URL=postgresql+asyncpg://domusmind:change_me_domusmind@postgres:5432/domusmind

# Redis
REDIS_PASSWORD=change_me_redis
REDIS_URL=redis://:change_me_redis@redis:6379/0
REDIS_SESSION_TTL=3600

# Home Assistant
HASS_URL=http://192.168.2.x:8123
HASS_TOKEN=

# LLM providers
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
LOCAL_MODEL=phi4
OLLAMA_BASE_URL=http://host.docker.internal:11434
LLM_FALLBACK_CHAIN=gemini,local,openai,claude

# Camera
CAMERA_IP=192.168.2.218
CAMERA_USER=admin
CAMERA_PASSWORD=
DEFAULT_CAMERA_SOURCE=0
YOLO_WEIGHTS=models/yolov8x.pt

# Audio
AUDIO_SAMPLE_RATE=16000
WHISPER_MODEL=medium
WHISPER_COMPUTE_TYPE=float32
TTS_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2
TTS_SPEAKER_WAV=models/Voz_Nielsen.wav
TTS_LANGUAGE=pt

# Embeddings
EMBEDDING_PROVIDER=google
EMBEDDING_DIM=768

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
